# ═══════════════════════════════════════════════════
#  MULTI-KEY OPENROUTER POOL — 3x faster throughput
# ═══════════════════════════════════════════════════
# Add up to 9 keys. Each key provides independent rate limits.
# Sign up at https://openrouter.ai — free & paid tiers available.

OPENROUTER_API_KEY_1=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
OPENROUTER_API_KEY_2=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
OPENROUTER_API_KEY_3=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

# Fallback: if no numbered keys, this single key is used
OPENROUTER_API_KEY=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

# ═══════════════════════════════════════════════════
#  MODEL SELECTION — Best OpenRouter models for research
# ═══════════════════════════════════════════════════
# Text model: Gemini 2.5 Flash — $0.30/M input, 1M context, excellent quality
OPENROUTER_MODEL=google/gemini-2.5-flash

# ═══════════════════════════════════════════════════
#  OLLAMA (Local) — Fallback when OpenRouter is rate-limited
# ═══════════════════════════════════════════════════
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:8b

# ═══════════════════════════════════════════════════
#  PAPERBANANA — Diagram Generation via OpenRouter
# ═══════════════════════════════════════════════════
# Dedicated key for PaperBanana pipeline (VLM + Image Gen)
PAPERBANANA_OPENROUTER_API_KEY=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
PAPERBANANA_TIMEOUT_SECONDS=240

# VLM model: google/gemini-2.5-flash (vision+text, $0.30/M input)
# Image model: google/gemini-2.5-flash-image (native image generation)